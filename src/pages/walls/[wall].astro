---
import { getCollection, getEntry } from 'astro:content'
import BaseLayout from '@/layouts/BaseLayout.astro'
import SetCard from '@/components/SetCard.astro'
import { getSetsForWall, currentSet, getRoutesForSet } from '@/lib/catalogue'

export const getStaticPaths = async () => {
  const walls = await getCollection('walls')
  return walls.map((wall) => ({ params: { wall: wall.id }, props: { wall } }))
}

const { wall } = Astro.props
const area = await getEntry(wall.data.area)

const sets = await getSetsForWall(wall.id)
const current = currentSet(sets)
const past = sets.filter((s) => s.data.stripDate)

const withRoutes = async (set: (typeof sets)[number]) => ({
  set,
  routes: await getRoutesForSet(set.id),
})
const currentRow = current ? await withRoutes(current) : null
const pastRows = await Promise.all(past.map(withRoutes))

const title = `Wall ${wall.data.number}`
---

<BaseLayout title={`${title}, ${area?.data.name ?? ''}`}>
  <a href="/" class="eyebrow hover:text-ink">&#8592; All walls</a>

  <header class="mt-4">
    <span class="eyebrow">{area?.data.name}</span>
    <h1 class="font-display mt-1 text-4xl sm:text-5xl">Wall {wall.data.number}</h1>
    {
      wall.data.features.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-1.5">
          {wall.data.features.map((feature) => (
            <span class="border-line text-muted font-mono rounded border px-1.5 py-0.5 text-xs">
              {feature}
            </span>
          ))}
        </div>
      )
    }
  </header>

  <section class="mt-8">
    <h2 class="eyebrow mb-3">Current set</h2>
    {
      currentRow ? (
        <SetCard set={currentRow.set} routes={currentRow.routes} />
      ) : (
        <p class="border-line text-muted rounded-lg border border-dashed px-4 py-3 text-sm eyebrow">
          Stripped &middot; awaiting reset
        </p>
      )
    }
  </section>

  {
    pastRows.length > 0 && (
      <section class="mt-10">
        <h2 class="eyebrow mb-3">Past sets</h2>
        <div class="space-y-4">
          {pastRows.map(({ set, routes }) => (
            <SetCard set={set} routes={routes} past />
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>
